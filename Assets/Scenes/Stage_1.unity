  unlockedCountText: {fileID: 2104281572}
  allKnowledges:
  - knowledgeId: leg_crossing
    title: "\uB2E4\uB9AC \uAF2C\uAE30"
    unlockedSprite: {fileID: 21300000, guid: 00c331ac8d7820b438d24abe6ebbb30e, type: 3}
    description: " \uB2E4\uB9AC \uAF2C\uC544 \uC549\uB294 \uC2B5\uAD00\uC740 \uACE8\uBC18
      \uD2C0\uC5B4\uC9D0\uACFC \uCC99\uCD94 \uCE35\uB9CC\uC99D\uC744 \uC720\uBC1C\uD558\uBA70,
      \uD558\uC9C0 \uC815\uB9E5\uB958\uC640 \uACE0\uD608\uC555\uC758 \uC6D0\uC778\uC774
      \uB418\uAE30\uB3C4 \uD569\uB2C8\uB2E4. \uB610\uD55C \uB0B4\uC7A5\uAE30\uAD00\uC758
      \uC555\uBC15\uC73C\uB85C \uC778\uD574 \uC18C\uD654\uAE30 \uAC74\uAC15\uC5D0\uB3C4
      \uC545\uC601\uD5A5\uC744 \uB07C\uCE69\uB2C8\uB2E4."
  - knowledgeId: slouching
    title: "\uB215\uB4EF\uC774 \uC549\uAE30"
    unlockedSprite: {fileID: 21300000, guid: cd79ada7f484d344eaa1421401bd0d3e, type: 3}
    description: " \uC77C\uC790 \uD5C8\uB9AC, \uD5C8\uB9AC \uB514\uC2A4\uD06C\uB97C
      \uC720\uBC1C\uD558\uBA70 \uACE8\uBC18 \uD6C4\uBC29 \uACBD\uC0AC\uC640 \uADFC\uC721
      \uC57D\uD654 \uB4F1\uC758 \uC9C8\uBCD1\uC744 \uC57C\uAE30\uD558\uB294 \uC790\uC138\uC785\uB2C8\uB2E4.
      \uB2E4\uB9AC \uC800\uB9BC, \uD1B5\uC99D, \uC77C\uC790\uBAA9\uACFC \uAC70\uBD81\uBAA9
      \uC99D\uD6C4\uAD70\uC758 \uC6D0\uC778\uB3C4 \uB420 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
